generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  CASHIER
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  country   String   @default("KE")
  createdAt DateTime @default(now()) @map("created_at")

  branches        Branch[]
  products        Product[]
  settings        StoreSettings?
  users           User[]
  rolePermissions RolePermission[]

  @@map("organizations")
}

model RolePermission {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  role           Role
  permission     String
  granted        Boolean  @default(false)
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, role, permission])
  @@map("role_permissions")
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  code           String
  isPrimary      Boolean  @default(false) @map("is_primary")
  address        String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization  Organization           @relation(fields: [organizationId], references: [id])
  transactions  InventoryTransaction[]
  devices       Device[]
  transfersFrom StockTransfer[]        @relation("TransferFrom")
  transfersTo   StockTransfer[]        @relation("TransferTo")
  users         User[]
  sales         Sale[]

  @@unique([organizationId, code])
  @@map("branches")
}

model User {
  id             String   @id @default(uuid())
  name           String
  pinHash        String   @map("pin_hash")
  role           Role
  organizationId String   @map("organization_id")
  branchId       String?  @map("branch_id")
  active         Boolean  @default(true)
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  branch       Branch?      @relation(fields: [branchId], references: [id])
  createdBy    User?        @relation("UserCreatedBy", fields: [createdById], references: [id])
  created      User[]       @relation("UserCreatedBy")
  sales        Sale[]

  @@index([organizationId])
  @@index([branchId])
  @@map("users")
}

model Sale {
  id                 String    @id
  organizationId     String    @map("organization_id")
  branchId           String    @map("branch_id")
  deviceId           String    @map("device_id")
  cashierId          String    @map("cashier_id")
  subtotal           Decimal
  lineDiscountTotal  Decimal   @default(0) @map("line_discount_total")
  saleDiscountAmount Decimal   @default(0) @map("sale_discount_amount")
  total              Decimal
  createdAt          DateTime  @default(now()) @map("created_at")
  syncedAt           DateTime? @map("synced_at")
  voidedAt           DateTime? @map("voided_at")
  voidedById         String?   @map("voided_by_id")
  voidReason         String?   @map("void_reason")

  branch  Branch                 @relation(fields: [branchId], references: [id])
  cashier User                   @relation(fields: [cashierId], references: [id])
  lines   InventoryTransaction[]

  @@index([branchId])
  @@index([cashierId])
  @@index([createdAt])
  @@map("sales")
}

model AuditEvent {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  branchId       String?  @map("branch_id")
  actorId        String   @map("actor_id")
  actorName      String   @map("actor_name")
  approvedById   String?  @map("approved_by_id")
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  metadata       Json?
  deviceId       String?  @map("device_id")
  wasOffline     Boolean  @default(false) @map("was_offline")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("audit_events")
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  REJECTED
  REVERSED
}

model StockTransfer {
  id           String         @id @default(uuid())
  fromBranchId String         @map("from_branch_id")
  toBranchId   String         @map("to_branch_id")
  productId    String         @map("product_id")
  quantity     Decimal
  status       TransferStatus @default(PENDING)
  note         String?
  fromDeviceId String         @map("from_device_id")
  toDeviceId   String?        @map("to_device_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  receivedAt   DateTime?      @map("received_at")

  fromBranch Branch  @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch  @relation("TransferTo", fields: [toBranchId], references: [id])
  product    Product @relation(fields: [productId], references: [id])

  @@map("stock_transfers")
}

model Unit {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isCustom  Boolean  @default(false) @map("is_custom")
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("units")
}

model Product {
  id             String  @id @default(uuid())
  name           String
  specification  String?
  stockUnit      String? @map("stock_unit")
  unitId         String? @map("unit_id")
  barcode        String? @unique
  sku            String  @unique
  sellingPrice   Decimal @map("selling_price")
  costPrice      Decimal @map("cost_price")
  lowestPrice    Decimal? @map("lowest_price")
  imageUrl       String? @map("image_url")
  category       String?
  brand          String  @default("UNBRANDED")
  quantity       String?
  organizationId String? @map("organization_id")
  createdAt      DateTime @default(now()) @map("created_at")

  unit         Unit?                  @relation(fields: [unitId], references: [id])
  organization Organization?          @relation(fields: [organizationId], references: [id])
  transactions InventoryTransaction[]
  incidents    Incident[]
  transfers    StockTransfer[]

  @@index([brand])
  @@index([unitId])
  @@index([organizationId])
  @@map("products")
}

enum TransactionType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  TRANSFER_OUT
}

enum TransactionSource {
  SUPPLIER
  INTERBRANCH
  CORRECTION
}

model InventoryTransaction {
  id                 String             @id @default(uuid())
  productId          String             @map("product_id")
  type               TransactionType
  source             TransactionSource? @map("source")
  sourceBranchId     String?            @map("source_branch_id")
  branchId           String?            @map("branch_id")
  quantity           Decimal
  unitPrice          Decimal?           @map("unit_price")
  saleId             String?            @map("sale_id")
  originalUnitPrice  Decimal?           @map("original_unit_price")
  lineDiscountAmount Decimal?           @map("line_discount_amount")
  deviceId           String             @map("device_id")
  createdAt          DateTime           @default(now()) @map("created_at")
  syncedAt           DateTime?          @map("synced_at")

  product Product @relation(fields: [productId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])
  sale    Sale?   @relation(fields: [saleId], references: [id])

  @@index([branchId])
  @@index([saleId])
  @@map("inventory_transactions")
}

model Device {
  id         String    @id
  name       String
  branchId   String?   @map("branch_id")
  lastSyncAt DateTime? @map("last_sync_at")

  branch Branch? @relation(fields: [branchId], references: [id])

  @@map("devices")
}

enum IncidentReason {
  OUT_OF_STOCK
  PRICE_TOO_HIGH
  NOT_AVAILABLE
  OTHER
}

model Incident {
  id          String         @id @default(uuid())
  productId   String?        @map("product_id")
  productName String         @map("product_name")
  reason      IncidentReason
  note        String?
  deviceId    String         @map("device_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  syncedAt    DateTime?      @map("synced_at")

  product Product? @relation(fields: [productId], references: [id])

  @@map("incidents")
}

model StoreSettings {
  id               String   @id @default("singleton")
  companyName      String   @default("My Business") @map("company_name")
  tagline          String   @default("")
  logoDataUrl      String   @default("") @map("logo_data_url")
  primaryColor     String   @default("#2563eb") @map("primary_color")
  currency         String   @default("KES")
  footerText       String   @default("Thank you for your business.") @map("footer_text")
  minMarkupPercent Decimal  @default(150) @map("min_markup_percent")
  posLookupMode    String   @default("catalog") @map("pos_lookup_mode")
  receiptFormat    String   @default("a4") @map("receipt_format")
  receiptTitle     String   @default("RECEIPT") @map("receipt_title")
  organizationId   String?  @unique @map("organization_id")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@map("store_settings")
}
